+    fun getMergeMangaList(mangaIds: List<Long>) =
+        db.get()
+            .listOfObjects(MergeMangaImpl::class.java)
+            .withQuery(
+                Query.builder()
+                    .table(MergeMangaTable.TABLE)
+                    .let { builder ->
+                        if (mangaIds.isEmpty()) builder.where("1 = 0")
+                        else builder.where("${MergeMangaTable.COL_MANGA_ID} IN (${Queries.placeholders(mangaIds.size)})").whereArgs(*mangaIds.toTypedArray())
+                    }
+                    .build()
+            )
+            .prepare()
